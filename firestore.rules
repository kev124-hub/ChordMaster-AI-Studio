rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User song library ────────────────────────────────────────────────────
    match /songs/{songId} {
      // Owner can create a song (resource is null on create, so check request.resource)
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      // Owner can read/update/delete their own songs
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      // Anyone can read a song that has been explicitly shared
      allow read: if resource.data.isShared == true;
    }

    // ── Analysis cache (read-only for clients) ───────────────────────────────
    // Written only by the backend (Firebase Admin SDK bypasses rules).
    match /analysis_cache/{cacheId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Job progress documents ───────────────────────────────────────────────
    // Created and updated exclusively by Firebase Functions (Admin SDK).
    // Each authenticated user may only read their own jobs.
    match /jobs/{jobId} {
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // ── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
